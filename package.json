{
	"name": "tcg-binder",
	"version": "1.0.2",
	"description": "Track your Pokémon TCG collection, build decks and browse cards inside your vault.",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"release": "node release.mjs",
		"release:minor": "node release.mjs minor",
		"release:major": "node release.mjs major"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"pokemon",
		"tcg",
		"collection",
		"deck-builder"
	],
	"author": "bgarciamoura",
	"license": "MIT",
	"dependencies": {
		"obsidian": "latest",
		"react": "^18.3.0",
		"react-dom": "^18.3.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.30.1",
		"@types/node": "^22.19.15",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"esbuild": "^0.27.4",
		"eslint": "^9.30.1",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"globals": "^14.0.0",
		"jiti": "^2.6.1",
		"tslib": "^2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.0"
	}
}
